# =============================================================================
# CHATBOT AUTOATENDIMENTO - SAAE SETE LAGOAS
# Copie este arquivo para .env e preencha os valores sensíveis
# =============================================================================

PORT=3000

# Identificador do município (usado no nome do container Docker)
MUNICIPIO=sete-lagoas

# =============================================================================
# SUPABASE (banco de dados e autenticação)
# =============================================================================
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY

# =============================================================================
# Z-API (instância WhatsApp)
# =============================================================================
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# =============================================================================
# SESSÃO
# =============================================================================
SESSION_MAX_INACTIVITY_MINUTES=15
SESSION_MAX_AGE_HOURS=24

# =============================================================================
# SMTP (envio de OTP por e-mail)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=SEU_EMAIL@gmail.com
SMTP_PASS=SUA_SENHA_DE_APP
SMTP_FROM="Atendimento MGF: Gestão Comercial Saneamento Gerenciamento - SAAE <SEU_EMAIL@gmail.com>"

# =============================================================================
# OTP (código de verificação)
# =============================================================================
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MOCK=false

# =============================================================================
# LINK API - GestCom (integração principal com o sistema do SAAE Sete Lagoas)
# Solicitar token ao suporte da GestCom
# =============================================================================
LINK_API_BASE_URL=https://ms.setelagoas.sistemagestcom.com.br/api/integracao/link
LINK_API_TOKEN=SEU_TOKEN_GESTCOM
LINK_API_MOCK=false

# ID de demonstração (usado apenas para testes)
DEMO_ID_ELETRONICO=SEU_ID_DEMO

# =============================================================================
# TELEFONE DA ENTIDADE (SAAE Sete Lagoas)
# Formato: DDI + DDD + número, sem espaços (ex: 5531999999999)
# =============================================================================
ENTIDADE_PHONE_NUMBER=5531XXXXXXXXX

# =============================================================================
# ATENDIMENTO PRESENCIAL - SAAE Sete Lagoas
# Para obter coordenadas: abrir Google Maps, clicar no local, copiar lat/lng
# =============================================================================
ATENDIMENTO_MAPS_URL=https://www.google.com/maps/dir/?api=1&destination=LAT,LNG
ATENDIMENTO_MAPS_TITLE=SAAE Sete Lagoas - Atendimento
ATENDIMENTO_MAPS_ADDRESS=Rua XXXXX, NNN - Centro, Sete Lagoas - MG, XXXXX-XXX
ATENDIMENTO_MAPS_LATITUDE=-19.XXXX
ATENDIMENTO_MAPS_LONGITUDE=-44.XXXX
ATENDIMENTO_MAPS_DESCRIPTION=Clique no link acima para abrir o Google Maps com a rota até o local de atendimento.

# =============================================================================
# MÍDIA (áudio de boas-vindas, menu e vídeo tutorial)
# Pode ser URL pública (https://...) ou base64 (data:audio/mpeg;base64,...)
# =============================================================================
WELCOME_AUDIO_URL=https://SEU_SERVIDOR/audio/welcome.mp3
MENU_AUDIO_URL=https://SEU_SERVIDOR/audio/menu.mp3
VIDEO_TUTORIAL_URL=https://SEU_SERVIDOR/video/tutorial.mp4
VIDEO_TUTORIAL_CAPTION=Aprenda como usar o autoatendimento do SAAE Sete Lagoas
VIDEO_TUTORIAL_INTRO=Este vídeo mostra como aproveitar todos os recursos do autoatendimento.
